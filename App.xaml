<Application x:Class="DeskAppWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DeskAppWPF"
             ThemeMode="Dark"
             xmlns:vm="clr-namespace:DeskAppWPF.ViewModels"
             xmlns:views="clr-namespace:DeskAppWPF.Views"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type vm:DeskControlViewModel}">
                <views:DeskControlView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            
            <!-- Sprint 2 — uncomment as each screen is built -->
            <!--
            <DataTemplate DataType="{x:Type vm:CalendarViewModel}">
                <views:CalendarView />
            </DataTemplate>

            

            <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                <views:ConnectionView />
            </DataTemplate>
            -->

        </ResourceDictionary>
    </Application.Resources>
</Application>

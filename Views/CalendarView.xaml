<UserControl x:Class="DeskAppWPF.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:DeskAppWPF.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:CalendarViewModel}"
             d:DesignHeight="800" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="20" BorderBrush="#303030" BorderThickness="0,0,0,1" Padding="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE787;" FontSize="24" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="Upcoming 5 Days" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Scrolling Content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            
            <!-- ItemsControl for 5 Days -->
            <ItemsControl ItemsSource="{Binding Days}" Margin="20,0,20,40">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:CalendarDayViewModel}">
                        <Grid Margin="0,0,0,40">
                            <!-- Left Date Label -->
                            <StackPanel HorizontalAlignment="Left" Width="80" Margin="0,10,0,0">
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:ddd}'}" FontSize="18" Foreground="#888888" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Date, StringFormat='{}{0:MM/dd}'}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-5,10,0"/>
                            </StackPanel>
                            
                            <!-- Day Layout (Hours on left starting after Date Label, lines extending right) -->
                            <Grid Margin="80,0,0,0">
                                <!-- Hour Lines drawn manually with ItemsControl for the 24 hours -->
                                <ItemsControl ItemsSource="{Binding Hours}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="60"> <!-- Each hour block is 60px high -->
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Hour text -->
                                                <TextBlock Grid.Column="0" Text="{Binding}" Foreground="#666666" FontSize="12" 
                                                           VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-8,10,0"/>
                                                <!-- Faded line -->
                                                <Border Grid.Column="1" BorderBrush="#303030" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Events List simply overlaid on the right, since it's hard to position events absolutely over specific hour heights purely in XAML without a custom Panel, we just list them out in front of the grid layout -->
                                <ItemsControl ItemsSource="{Binding DayEvents}" Margin="60,30,10,0" VerticalAlignment="Top">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewmodels:CalendarEventViewModel}">
                                            <!-- Calendar Event Card -->
                                            <Border Background="#2B2B2B" CornerRadius="8" Margin="0,0,0,10" Padding="15" 
                                                    BorderBrush="#107C10" BorderThickness="2,1,1,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <TextBlock Foreground="#A0A0A0" FontSize="12" Margin="0,5,0,0">
                                                            <Run Text="{Binding StartTime, StringFormat='{}{0:h:mm tt}'}" />
                                                            <Run Text=" - " />
                                                            <Run Text="{Binding EndTime, StringFormat='{}{0:h:mm tt}'}" />
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Action Checkbox -->
                                                    <CheckBox Grid.Column="1" 
                                                              IsChecked="{Binding IsChecked}" 
                                                              Command="{Binding ToggleCheckedCommand}"
                                                              VerticalAlignment="Bottom" 
                                                              HorizontalAlignment="Right">
                                                        <CheckBox.LayoutTransform>
                                                            <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                                        </CheckBox.LayoutTransform>
                                                    </CheckBox>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="DeskAppWPF.Views.DeskControlView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DeskAppWPF.Views" xmlns:viewmodels="clr-namespace:DeskAppWPF.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:DeskControlViewModel}"
             mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding CurrentHeight}"/>
        <Button 
            Content="Refresh"
            Command="{Binding LoadHeightCommand}"></Button>
        <StackPanel Grid.Column="1" Orientation="Horizontal">

            <Button 
            Content="1"
            Command="{Binding SetPresetCommand}"
            CommandParameter="1"></Button>
        <Button 
            Content="2"
            Command="{Binding SetPresetCommand}"
            CommandParameter="2"></Button>
        <Button 
            Content="3"
            Command="{Binding SetPresetCommand}"
            CommandParameter="3"></Button>
        <Button 
            Content="4"
            Command="{Binding SetPresetCommand}"
            CommandParameter="4"></Button>
        </StackPanel>

    </Grid>
</UserControl>

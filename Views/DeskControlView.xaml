<UserControl x:Class="DeskAppWPF.Views.DeskControlView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DeskAppWPF.Views" xmlns:viewmodels="clr-namespace:DeskAppWPF.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:DeskControlViewModel}"
             mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- First Column: Control Panel -->
        <Grid Grid.Column="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Left: Connection Status -->
            <StackPanel Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                    <Ellipse Width="12" Height="12" Fill="#107C10" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Connected" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center" FontSize="14"/>
                </StackPanel>
                <Border Height="1" Background="#E0E0E0" Margin="0,0,0,0"/>
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="10,0">
                
                <!-- Height Display -->
                <Grid HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock x:Name="HeightText" 
                               Text="{Binding CurrentHeight, StringFormat='{}{0:f2}&quot;'}" 
                               FontSize="100" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center" Padding="0" Margin="0"/>
                    
                    <Viewbox Grid.Row="1" Width="{Binding ActualWidth, ElementName=HeightText}" Stretch="Uniform" Margin="0,-10,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="current height" Foreground="#888888" FontWeight="SemiBold" TextAlignment="Center"/>
                    </Viewbox>
                </Grid>

                <!-- Presets -->
                <UniformGrid Columns="2" Rows="2" Margin="0,40,0,0" HorizontalAlignment="Stretch">
                    <Button Content="Preset 1" Command="{Binding SetPresetCommand}" CommandParameter="1" Margin="5" Padding="0,20" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                    <Button Content="Preset 2" Command="{Binding SetPresetCommand}" CommandParameter="2" Margin="5" Padding="0,20" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                    <Button Content="Preset 3" Command="{Binding SetPresetCommand}" CommandParameter="3" Margin="5" Padding="0,20" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                    <Button Content="Preset 4" Command="{Binding SetPresetCommand}" CommandParameter="4" Margin="5" Padding="0,20" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                </UniformGrid>

                <!-- Stop Button -->
                <Button Content="STOP" Background="#D13438" Foreground="White" FontWeight="Bold" FontSize="18"
                        Margin="5,10,5,0" Padding="0,20" HorizontalAlignment="Stretch"/>
                
            </StackPanel>
        </Grid>

        <!-- Second Column -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top Right Settings Button -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Background="Transparent" BorderThickness="0" Padding="8" Margin="0,0,0,10"
                    Command="{Binding NavigateCommand}" CommandParameter="Settings">
                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" FontSize="20" Foreground="#888888"/>
            </Button>

            <!-- Upcoming Event / Calendar View -->
            <ContentControl Content="{Binding CalendarViewModel}" Grid.Row="1" Margin="10"/>
        </Grid>
    </Grid>
</UserControl>
